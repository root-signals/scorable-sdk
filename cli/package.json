{
  "name": "@root-signals/scorable-cli",
  "version": "0.1.3",
  "description": "CLI for Scorable",
  "license": "Apache-2.0",
  "author": "Scorable",
  "bin": {
    "scorable": "./dist/index.js",
    "scorable-cli": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --target=node18 --format=cjs --minify --banner:js='#!/usr/bin/env node' --log-override:empty-import-meta=silent --outfile=dist/scorable.cjs && chmod +x dist/scorable.cjs",
    "check-all": "npm run typecheck && npm run lint && npm run fmt:check && npm run test",
    "prepublishOnly": "npm run check-all && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src tests",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@root-signals/scorable": "^0.2.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "esbuild": "^0.25.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
